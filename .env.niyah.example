# ════════════════════════════════════════════════════════════════════
# NIYAH ENGINE v3 · .env
# Copy to .env.local — never commit real keys
# نحن ورثة الخوارزمي
# ════════════════════════════════════════════════════════════════════

# ── SOVEREIGN LOCAL (zero cloud) ────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
HAVEN_OLLAMA_MODEL=qwen2.5-coder:7b
# Other good local models:
#   qwen2.5-coder:32b   ← best code, slow
#   llama3.3:70b        ← best Arabic + reasoning, slow
#   phi4:14b            ← fast reasoning
#   mistral-nemo:12b    ← fast general

# ── CLOUD KEYS (optional — engine falls back gracefully) ─────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ── ENGINE TUNING ────────────────────────────────────────────────────
NIYAH_LOG=false          # true = verbose routing logs
NIYAH_MAX_RETRIES=3      # fallback attempts before error
